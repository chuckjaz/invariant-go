[Unit]
Description=Invariant Distribute Service
After=network.target invariant-discovery.service
Wants=invariant-discovery.service

[Service]
Type=simple
User=invariant
Group=invariant
Environment="DISCOVERY_URL=http://localhost:3003"
ExecStart=/usr/local/bin/distribute -port 3001 -discovery ${DISCOVERY_URL} -name distribute-1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
