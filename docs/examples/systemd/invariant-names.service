[Unit]
Description=Invariant Names Service
After=network.target invariant-discovery.service
Wants=invariant-discovery.service

[Service]
Type=simple
User=invariant
Group=invariant
Environment="DISCOVERY_URL=http://localhost:3003"
ExecStart=/usr/local/bin/names -port 3005 -dir /var/lib/invariant/names -discovery ${DISCOVERY_URL}
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
